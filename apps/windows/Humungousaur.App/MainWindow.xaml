                                            <DataTemplate>
                                                <StackPanel Margin="0,5">
                                                    <TextBlock Text="{Binding RecordStatus}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding RecordTitle}" TextWrapping="WrapWholeWords" />
                                                    <TextBlock Text="{Binding RecordSubtitle}" Opacity="0.62" FontSize="12" TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
