<Window
    x:Class="Humungousaur.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Humungousaur.App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Humungousaur">

    <Window.Resources>
        <SolidColorBrush x:Key="AppCanvasBrush" Color="#F6F7F4" />
        <SolidColorBrush x:Key="AppPaneBrush" Color="#F0F2EF" />
        <SolidColorBrush x:Key="AppCardBrush" Color="#FDFDFC" />
        <SolidColorBrush x:Key="AppSubtleBrush" Color="#F4F5F2" />
        <SolidColorBrush x:Key="AppStrokeBrush" Color="#1A111827" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#8A111827" />
        <SolidColorBrush x:Key="AssistantAccentBrush" Color="#C43126" />
        <SolidColorBrush x:Key="AssistantAccentSoftBrush" Color="#1FC43126" />
        <SolidColorBrush x:Key="AssistantWarmBrush" Color="#B45309" />

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{StaticResource AppCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="CompactCardBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{StaticResource AppCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AppStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="32" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="LineHeight" Value="36" />
        </Style>

        <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="MonoTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{StaticResource AppCanvasBrush}" RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Padding="20,0" Background="{StaticResource AppCanvasBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Image
                    Width="38"
                    Height="38"
                    Source="Assets/humungousaur-logo-mark-64.png"
                    Stretch="Uniform"
                    AutomationProperties.Name="Humungousaur" />
                <StackPanel>
                    <TextBlock Text="Humungousaur" FontSize="17" FontWeight="SemiBold" />
                    <TextBlock x:Name="WorkspaceCaption" Text="Personal assistant shell" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Border Padding="11,6" CornerRadius="8" Background="{StaticResource AppCardBrush}" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#9CA3AF" VerticalAlignment="Center" />
                        <TextBlock x:Name="StatusText" Text="Checking" FontSize="12" />
                    </StackPanel>
                </Border>
                <Button x:Name="RefreshButton" Click="RefreshButton_Click" ToolTipService.ToolTip="Refresh">
                    <FontIcon Glyph="&#xE72C;" />
                </Button>
            </StackPanel>
        </Grid>

        <NavigationView
            x:Name="ShellNav"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            IsPaneOpen="True"
            OpenPaneLength="286"
            PaneDisplayMode="Left"
            PaneTitle="Control"
            SelectionChanged="ShellNav_SelectionChanged">
            <NavigationView.PaneHeader>
                <StackPanel Padding="18,16,18,10" Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="11">
                        <Image Width="38" Height="38" Source="Assets/humungousaur-logo-mark-64.png" Stretch="Uniform" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="CONTROL" FontSize="11" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock Text="Humungousaur" FontSize="16" FontWeight="SemiBold" />
                        </StackPanel>
                    </StackPanel>
                    <Border Padding="10,8" CornerRadius="8" Background="{StaticResource AppSubtleBrush}" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="1">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Ellipse x:Name="PaneStatusDot" Width="8" Height="8" Fill="#9CA3AF" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Local runtime link" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                        </Grid>
                    </Border>
                </StackPanel>
            </NavigationView.PaneHeader>
            <NavigationView.MenuItems>
                <NavigationViewItemHeader Content="Chat" />
                <NavigationViewItem Content="Chat" Tag="assistant">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8BD;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemHeader Content="Control" />
                <NavigationViewItem Content="Overview" Tag="assistant">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Runs" Tag="runtime">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE916;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Permissions" Tag="runtime">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8FB;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Autonomy" Tag="autonomy">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemHeader Content="Agent" />
                <NavigationViewItem Content="Capabilities" Tag="tools">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Channels" Tag="channels">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8F2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Voice" Tag="voice">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE720;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemHeader Content="Settings" />
                <NavigationViewItem Content="Settings" Tag="settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.PaneFooter>
                <Border Margin="12" Padding="10,9" CornerRadius="8" Background="{StaticResource AppSubtleBrush}" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="1">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE77B;" FontSize="17" Foreground="{StaticResource MutedTextBrush}" />
                        <StackPanel Grid.Column="1" Spacing="1">
                            <TextBlock Text="Local user" FontSize="13" FontWeight="SemiBold" />
                            <TextBlock Text="Runtime state is local" FontSize="11" Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </NavigationView.PaneFooter>

            <Grid Padding="28" Background="{StaticResource AppCanvasBrush}">
                <InfoBar
                    x:Name="NoticeBar"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    IsOpen="False"
                    Severity="Informational"
                    Title="Humungousaur" />

                <Grid x:Name="AssistantPage" Margin="0,42,0,0" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.15*" />
                        <ColumnDefinition Width="380" />
                    </Grid.ColumnDefinitions>
                    <Grid RowSpacing="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Spacing="5">
                            <TextBlock Text="Runtime" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AssistantAccentBrush}" />
                            <TextBlock Text="Command Center" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="A quiet Windows command surface for chat, runtime health, approvals, capabilities, channels, voice, and bounded autonomy." Style="{StaticResource PageSubtitleStyle}" />
                        </StackPanel>
                        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Padding="0">
                            <ListView x:Name="ChatLog" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="8,5" Padding="13,11" Background="{StaticResource AppSubtleBrush}" CornerRadius="8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding Speaker}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding TimeText}" Opacity="0.58" FontSize="12" />
                                                </StackPanel>
                                                <TextBlock Grid.Row="1" Text="{Binding Text}" TextWrapping="WrapWholeWords" Margin="0,5,0,0" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>
                        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="14">
                            <Grid RowSpacing="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBox x:Name="PromptBox" AcceptsReturn="True" MinHeight="92" TextWrapping="Wrap" PlaceholderText="Ask, dictate, attach context, or simulate a stimulus" />
                                <Grid Grid.Row="1" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="StimulusSourceBox" SelectedIndex="0" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="User text" Tag="user_text" />
                                        <ComboBoxItem Content="Voice transcript" Tag="voice_transcript" />
                                        <ComboBoxItem Content="Activity" Tag="activity" />
                                    </ComboBox>
                                    <ComboBox x:Name="ResponseModeBox" Grid.Column="1" SelectedIndex="0" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="Text" Tag="text" />
                                        <ComboBoxItem Content="Prepare voice" Tag="voice_prepare" />
                                        <ComboBoxItem Content="Speak" Tag="voice_speak" />
                                        <ComboBoxItem Content="Silent" Tag="silent" />
                                    </ComboBox>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button Content="System" Click="QuickSystemButton_Click" />
                                        <Button Content="Status" Click="QuickAutonomyButton_Click" />
                                        <Button Content="Channels" Click="QuickChannelsButton_Click" />
                                    </StackPanel>
                                    <Button Grid.Column="3" x:Name="SendButton" Click="SendButton_Click" Background="{StaticResource AssistantAccentBrush}" Foreground="White">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE724;" />
                                            <TextBlock Text="Send" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="1" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Runtime" Style="{StaticResource CardTitleStyle}" />
                                <TextBlock x:Name="RuntimeSummaryText" Text="Waiting for API" TextWrapping="WrapWholeWords" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="StartAgentButton" Content="Start" Click="StartAgentButton_Click" />
                                    <Button x:Name="StopAgentButton" Content="Stop" Click="StopAgentButton_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Capability Pulse" Style="{StaticResource CardTitleStyle}" />
                                <Grid ColumnSpacing="12" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock x:Name="ToolCountText" Text="Tools -" />
                                    <TextBlock x:Name="ChannelCountText" Grid.Column="1" Text="Channels -" />
                                    <TextBlock x:Name="VoiceReadyText" Grid.Row="1" Text="Voice -" />
                                    <TextBlock x:Name="AutonomyReadyText" Grid.Row="1" Grid.Column="1" Text="Loop -" />
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Process Log" Style="{StaticResource CardTitleStyle}" />
                                <ListView x:Name="ProcessLog" SelectionMode="None" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <Grid x:Name="ChannelsPage" Margin="0,42,0,0" Visibility="Collapsed" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Spacing="5">
                            <TextBlock Text="Agent" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AssistantAccentBrush}" />
                            <TextBlock Text="Channels" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="Onboard chat surfaces, preview gateway paths, and keep external-visible work approval-gated." Style="{StaticResource PageSubtitleStyle}" />
                        </StackPanel>
                        <ListView x:Name="ChannelList" Grid.Row="1" SelectionChanged="ChannelList_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,5">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Transport}" Opacity="0.64" FontSize="12" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                    <Grid Grid.Column="1" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock x:Name="ChannelTitleText" Text="Select a channel" Style="{StaticResource CardTitleStyle}" FontSize="20" />
                                <TextBlock x:Name="ChannelCapabilityText" TextWrapping="WrapWholeWords" Opacity="0.72" />
                                <TextBlock x:Name="ChannelStatusText" TextWrapping="WrapWholeWords" Opacity="0.72" />
                                <TextBlock x:Name="ChannelListenerText" TextWrapping="WrapWholeWords" Opacity="0.72" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Onboarding" FontWeight="SemiBold" />
                                    <TextBlock x:Name="ChannelRequirementText" TextWrapping="WrapWholeWords" Opacity="0.76" />
                                    <ScrollViewer MaxHeight="132">
                                        <TextBlock x:Name="ChannelSetupStepsText" TextWrapping="WrapWholeWords" />
                                    </ScrollViewer>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Doctor" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <Button Content="Run doctor" Click="RunChannelDoctorButton_Click" />
                                        <Button Content="Run smoke" Click="RunChannelSmokeButton_Click" />
                                    </StackPanel>
                                    <TextBlock x:Name="ChannelPolicyText" TextWrapping="WrapWholeWords" Opacity="0.76" />
                                    <ScrollViewer MaxHeight="132">
                                        <StackPanel Spacing="8">
                                            <TextBlock x:Name="ChannelDoctorText" TextWrapping="WrapWholeWords" />
                                            <TextBlock x:Name="ChannelSmokeText" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </ScrollViewer>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                            <Grid RowSpacing="10" ColumnSpacing="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <ToggleSwitch x:Name="ChannelEnabledSwitch" Header="Enabled" />
                                    <ToggleSwitch x:Name="ChannelListenSwitch" Header="Listen" />
                                </StackPanel>
                                <ComboBox x:Name="ConversationTypeBox" Grid.Column="1" Header="Conversation" SelectedIndex="0">
                                    <ComboBoxItem Content="DM" Tag="dm" />
                                    <ComboBoxItem Content="Room" Tag="room" />
                                    <ComboBoxItem Content="Channel" Tag="channel" />
                                    <ComboBoxItem Content="Group" Tag="group" />
                                </ComboBox>
                                <TextBox x:Name="ConversationIdBox" Grid.Row="1" Header="Conversation id" PlaceholderText="workspace room, DM, or pairing id" />
                                <TextBox x:Name="SecretNameBox" Grid.Row="1" Grid.Column="1" Header="Secret name" PlaceholderText="SLACK_BOT_TOKEN" />
                                <PasswordBox x:Name="ChannelSecretBox" Grid.Row="2" Header="Token or pairing note" PlaceholderText="Kept out of saved settings" />
                                <TextBox x:Name="ChannelNotesBox" Grid.Row="2" Grid.Column="1" Header="Setup notes" />
                                <TextBox x:Name="ChannelSecretsBox" Grid.Row="3" Grid.ColumnSpan="2" Header="Channel secrets" AcceptsReturn="True" MinHeight="74" PlaceholderText="SLACK_BOT_TOKEN=xoxb-...&#x0a;WHATSAPP_PHONE_NUMBER_ID=..." TextWrapping="NoWrap" />
                                <TextBox x:Name="ChannelAllowlistBox" Grid.Row="4" Header="Allowed senders" AcceptsReturn="True" MinHeight="62" PlaceholderText="U123&#x0a;+15555550100" TextWrapping="NoWrap" />
                                <TextBox x:Name="ChannelGroupAllowlistBox" Grid.Row="4" Grid.Column="1" Header="Allowed rooms/groups" AcceptsReturn="True" MinHeight="62" PlaceholderText="C123&#x0a;chat-42" TextWrapping="NoWrap" />
                                <TextBox x:Name="ChannelOutboundTextBox" Grid.Row="5" Grid.ColumnSpan="2" Header="Outbound message" AcceptsReturn="True" MinHeight="78" PlaceholderText="Prepare a reply or approved send for this channel" TextWrapping="Wrap" />
                                <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="SaveChannelButton" Content="Save setup" Click="SaveChannelButton_Click" />
                                    <Button x:Name="TestChannelButton" Content="Preview inbound" Click="TestChannelButton_Click" />
                                    <Button x:Name="PrepareOutboundButton" Content="Prepare outbound" Click="PrepareOutboundButton_Click" />
                                    <Button x:Name="SendOutboundButton" Content="Send approved" Click="SendOutboundButton_Click" />
                                    <Button x:Name="TickChannelButton" Content="Poll now" Click="TickChannelButton_Click" />
                                    <Button x:Name="TickAllChannelsButton" Content="Poll all" Click="TickAllChannelsButton_Click" />
                                    <Button Content="Refresh listeners" Click="RefreshListenersButton_Click" />
                                    <Button Content="Refresh outbox" Click="RefreshOutboxButton_Click" />
                                </StackPanel>
                                <Grid Grid.Row="7" Grid.ColumnSpan="2" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleSwitch x:Name="ContinuousChannelListenSwitch" Header="Listen loop" Toggled="ContinuousChannelListenSwitch_Toggled" />
                                    <TextBox x:Name="ChannelListenIntervalBox" Grid.Column="1" Header="Poll sec" Text="30" />
                                    <TextBlock x:Name="ChannelListenLoopText" Grid.Column="2" Text="Listening loop stopped." TextWrapping="WrapWholeWords" VerticalAlignment="Bottom" Opacity="0.72" />
                                </Grid>
                            </Grid>
                        </Border>
                        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Prepared Replies" Style="{StaticResource CardTitleStyle}" />
                                <ListView x:Name="OutboxList" SelectionMode="None" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <Grid x:Name="VoicePage" Margin="0,42,0,0" Visibility="Collapsed" RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="5">
                        <TextBlock Text="Agent" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AssistantAccentBrush}" />
                        <TextBlock Text="Voice" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="Deepgram input, ElevenLabs or Windows speech output, and wakeup-response preferences." Style="{StaticResource PageSubtitleStyle}" />
                    </StackPanel>
                    <Grid Grid.Row="1" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Speech to Text" Style="{StaticResource CardTitleStyle}" />
                                <TextBlock x:Name="DeepgramStatusText" Text="-" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Text to Speech" Style="{StaticResource CardTitleStyle}" />
                                <TextBlock x:Name="ElevenLabsStatusText" Text="-" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Windows Voice" Style="{StaticResource CardTitleStyle}" />
                                <TextBlock x:Name="SystemVoiceStatusText" Text="-" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="TtsProviderBox" Header="TTS provider" SelectedIndex="0">
                                    <ComboBoxItem Content="Windows SAPI" Tag="system" />
                                    <ComboBoxItem Content="ElevenLabs" Tag="elevenlabs" />
                                </ComboBox>
                                <TextBox x:Name="VoiceIdBox" Grid.Column="1" Header="Voice id" />
                                <Button Grid.Column="2" VerticalAlignment="Bottom" Content="Save voice" Click="SaveVoiceButton_Click" />
                            </Grid>
                            <Grid Grid.Row="1" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="DeepgramApiKeyBox" Header="Deepgram API key" />
                                <PasswordBox x:Name="ElevenLabsApiKeyBox" Grid.Column="1" Header="ElevenLabs API key" />
                                <TextBox x:Name="ElevenLabsModelBox" Grid.Column="2" Header="ElevenLabs model" PlaceholderText="eleven_multilingual_v2" />
                            </Grid>
                            <TextBox x:Name="VoiceTestBox" Grid.Row="2" Text="I am online and ready to help." Header="Test phrase" />
                            <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
                                <Button Content="Refresh voice" Click="RefreshVoiceButton_Click" />
                                <Button Content="Speak test" Click="SpeakTestButton_Click" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Grid x:Name="AutonomyPage" Margin="0,42,0,0" Visibility="Collapsed" RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="5">
                        <TextBlock Text="Control" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AssistantAccentBrush}" />
                        <TextBlock Text="Autonomy" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="Runtime queue, wakeups, trigger cycles, and bounded initiative controls." Style="{StaticResource PageSubtitleStyle}" />
                    </StackPanel>
                    <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <ToggleSwitch x:Name="AllowInitiativeSwitch" Header="Initiative" />
                            <TextBox x:Name="MaxCyclesBox" Header="Max cycles" Text="1" Width="120" />
                            <TextBox x:Name="LoopIntervalBox" Header="Interval sec" Text="60" Width="130" />
                            <ToggleSwitch x:Name="ContinuousLoopSwitch" Header="Continuous" Toggled="ContinuousLoopSwitch_Toggled" />
                            <Button Content="Run cycle" VerticalAlignment="Bottom" Click="RunCycleButton_Click" />
                            <Button Content="Refresh" VerticalAlignment="Bottom" Click="RefreshAutonomyButton_Click" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                        <ScrollViewer>
                            <TextBlock x:Name="AutonomyStatusText" TextWrapping="WrapWholeWords" Style="{StaticResource MonoTextStyle}" />
                        </ScrollViewer>
                    </Border>
                </Grid>

                <Grid x:Name="RuntimePage" Margin="0,42,0,0" Visibility="Collapsed" ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="330" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Spacing="5">
                            <TextBlock Text="Control" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AssistantAccentBrush}" />
                            <TextBlock Text="Runs" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="Runs, approvals, and execution evidence." Style="{StaticResource PageSubtitleStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                            <Button Content="Refresh" Click="RefreshRuntimeButton_Click" />
                            <Button Content="Cancel run" Click="CancelRunButton_Click" />
                        </StackPanel>
                        <ListView x:Name="RuntimeRunList" Grid.Row="2" SelectionChanged="RuntimeRunList_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,5">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Subtitle}" TextTrimming="CharacterEllipsis" Opacity="0.64" FontSize="12" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                    <Grid Grid.Column="1" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="220" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Spacing="5">
                            <TextBlock Text="Permissions" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AssistantAccentBrush}" />
                            <TextBlock Text="Approvals" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock Text="Review high-risk actions before the agent executes them." Style="{StaticResource PageSubtitleStyle}" />
                        </StackPanel>
                        <Border Grid.Row="1" Style="{StaticResource CompactCardBorderStyle}">
                            <ListView x:Name="ApprovalList" SelectionChanged="ApprovalList_SelectionChanged">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,5">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Subtitle}" TextTrimming="CharacterEllipsis" Opacity="0.64" FontSize="12" />
                                            <TextBlock Text="{Binding ShortToken}" Opacity="0.54" FontSize="11" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>
                        <Grid Grid.Row="2" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ApprovalNoteBox" PlaceholderText="Approval note" />
                            <Button Grid.Column="1" Content="Approve" Click="ApproveSelectedButton_Click" />
                            <Button Grid.Column="2" Content="Reject" Click="RejectSelectedButton_Click" />
                            <Button Grid.Column="3" Content="Refresh" Click="RefreshRuntimeButton_Click" />
                        </Grid>
                        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}">
                            <ScrollViewer>
                                <TextBlock x:Name="RuntimeDetailText" TextWrapping="WrapWholeWords" Style="{StaticResource MonoTextStyle}" />
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <Grid x:Name="ToolsPage" Margin="0,42,0,0" Visibility="Collapsed" ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="330" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Spacing="5">
                            <TextBlock Text="Agent" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AssistantAccentBrush}" />
                            <TextBlock Text="Capabilities" Style="{StaticResource PageTitleStyle}" />
                            <TextBlock x:Name="ToolsSummaryText" Text="-" Style="{StaticResource PageSubtitleStyle}" />
                        </StackPanel>
                        <ListView x:Name="ToolGroupList" Grid.Row="1" SelectionMode="None" />
                    </Grid>
                    <Grid Grid.Column="1" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBox x:Name="ToolSearchBox" PlaceholderText="Filter tools" TextChanged="ToolSearchBox_TextChanged" />
                        <ListView x:Name="ToolList" Grid.Row="1" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,5" Padding="12" Background="{StaticResource AppCardBrush}" CornerRadius="8" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding CapabilityGroup}" Opacity="0.62" />
                                                <TextBlock Text="{Binding RiskLevel}" Foreground="{StaticResource AssistantWarmBrush}" />
                                            </StackPanel>
                                            <TextBlock Grid.Row="1" Text="{Binding Description}" TextWrapping="WrapWholeWords" Opacity="0.78" Margin="0,4,0,0" />
                                            <TextBlock Grid.Row="2" Text="{Binding RequiresApproval}" Opacity="0.62" FontSize="12" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>

                <Grid x:Name="SettingsPage" Margin="0,42,0,0" Visibility="Collapsed" RowSpacing="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="5">
                        <TextBlock Text="Settings" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AssistantAccentBrush}" />
                        <TextBlock Text="Settings" Style="{StaticResource PageTitleStyle}" />
                        <TextBlock Text="Runtime connection, model defaults, workspace, and local process startup." Style="{StaticResource PageSubtitleStyle}" />
                    </StackPanel>
                    <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                        <Grid RowSpacing="12" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBox x:Name="ApiBaseUrlBox" Header="API base URL" />
                            <TextBox x:Name="PortBox" Grid.Column="1" Header="Port" />
                            <TextBox x:Name="WorkspacePathBox" Grid.Row="1" Grid.ColumnSpan="2" Header="Workspace path" />
                            <TextBox x:Name="PythonPathBox" Grid.Row="2" Header="Python path" PlaceholderText="python" />
                            <ComboBox x:Name="PlannerBox" Grid.Row="2" Grid.Column="1" Header="Planner" SelectedIndex="0">
                                <ComboBoxItem Content="Model" Tag="model" />
                                <ComboBoxItem Content="Explicit" Tag="explicit" />
                            </ComboBox>
                            <ComboBox x:Name="ModelProviderBox" Grid.Row="3" Header="Model provider" SelectedIndex="0">
                                <ComboBoxItem Content="OpenAI" Tag="openai" />
                                <ComboBoxItem Content="Groq" Tag="groq" />
                                <ComboBoxItem Content="Grok" Tag="grok" />
                                <ComboBoxItem Content="Ollama" Tag="ollama" />
                                <ComboBoxItem Content="Local OpenAI" Tag="local-openai" />
                            </ComboBox>
                            <TextBox x:Name="ModelNameBox" Grid.Row="3" Grid.Column="1" Header="Model override" />
                            <TextBox x:Name="ModelBaseUrlBox" Grid.Row="4" Header="Model base URL" PlaceholderText="https://api.groq.com/openai/v1" />
                            <PasswordBox x:Name="ModelApiKeyBox" Grid.Row="4" Grid.Column="1" Header="Model API key" />
                            <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="10">
                                <ToggleSwitch x:Name="ApproveHighRiskSwitch" Header="Approve high risk" />
                                <Button Content="Save settings" Click="SaveSettingsButton_Click" />
                                <Button Content="Start agent" Click="StartAgentButton_Click" />
                                <Button Content="Stop agent" Click="StopAgentButton_Click" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
