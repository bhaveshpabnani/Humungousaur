                                                    <StackPanel Margin="0,5">
                                                        <TextBlock Text="{Binding RecordTitle}" TextWrapping="WrapWholeWords" />
                                                        <TextBlock Text="{Binding RecordSubtitle}" Opacity="0.62" FontSize="12" TextWrapping="WrapWholeWords" />
